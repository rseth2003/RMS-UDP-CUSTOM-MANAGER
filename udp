# Helper to get Hysteria config
get_hysteria_config() {
  grep -vE \'^(listen|tls|obfs|auth|masquerade)\' /etc/hysteria/config.yaml | grep -v \'^$\'
}

# Helper to update Hysteria config
update_hysteria_config() {
  local new_users=\"$1\"
  local current_config=$(get_hysteria_config)
  cat > /etc/hysteria/config.yaml << EOF
listen: :36713

tls:
  cert: /etc/hysteria/cert.pem
  key: /etc/hysteria/key.pem

obfs:
  type: salamander
  salamander:
    password: rmsobfs2026

auth:
  type: userpass
  userpass:
$new_users

masquerade:
  type: proxy
  proxy:
    url: https://www.google.com
    rewriteHost: true
EOF
  systemctl restart hysteria
}

# Show Hysteria Users
show_hysteria_users() {
  grep -A 999 \'userpass:\' /etc/hysteria/config.yaml | grep -vE \'^(userpass:|masquerade:|proxy:|url:|rewriteHost:)\' | sed \'s/^    //\' | awk -F\':\' \'{print $1}\'
}

# Hysteria Data User
data_hysteria_user() {
  local hysteria_users=$(show_hysteria_users)
  if [[ -z \"$hysteria_users\" ]]; then
    echo -e \" ${YELLOW}  вҡ   No Hysteria2 users registered yet${NC}\"
    return 1
  fi
  echo -e \" ${CYAN}$(printf \'%-3s %-12s %-12s %-18s %-14s %s\' \'#\' \'USER\' \'PASS\' \'EXPIRES\' \'REMAINING\' \'STATUS\')${NC}\"
  echo -e \" ${CYAN}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}\"

  i=1
  while read u;
  do
    local pass=$(grep -A 1 \"$u:\" /etc/hysteria/config.yaml | tail -n 1 | awk -F\':\' \'{print $2}\' | sed \'s/ //g\')
    local exp_ts=$(cat \"/etc/rms-users/${u}.hysteria.expiry\" 2>/dev/null)
    local exp_display=\"N/A\"
    local remaining=\"N/A\"
    local stat=\"${GREEN}в—Ҹ ULK${NC}\"

    if [[ -n \"$exp_ts\" ]]; then
      exp_display=$(date -d \"@$exp_ts\" \'+%Y-%m-%d %H:%M\')
      now=$(date +%s)
      remaining_s=$(( exp_ts - now ))
      if [[ $remaining_s -le 0 ]]; then
        remaining=\"${RED}Expired${NC}\"
        stat=\"${RED}в—Ҹ BLK${NC}\"
      else
        rem_h=$(( remaining_s / 3600 ))
        rem_m=$(( (remaining_s % 3600) / 60 ))
        rem_s=$(( remaining_s % 60 ))
        if [[ $rem_h -gt 0 ]]; then
          remaining=\"${GREEN}${rem_h}h ${rem_m}m${NC}\"
        elif [[ $rem_m -gt 0 ]]; then
          remaining=\"${YELLOW}${rem_m}m ${rem_s}s${NC}\"
        else
          remaining=\"${RED}${rem_s}s${NC}\"
        fi
      fi
    fi
    echo -e \" ${ORANGE}$(printf \'%-3s\' \"$i\") ${NC} ${WHITE}$(printf \'%-12s\' \"$u\") ${NC} ${WHITE}$(printf \'%-12s\' \"$pass\") ${NC} ${CYAN}$(printf \'%-18s\' \"$exp_display\") ${NC} $remaining  $stat\"
    let i++
  done <<<\"$hysteria_users\"
}

