# ======== SHOW USERS ========
show_users() {
  for u in $(cat /etc/passwd | grep 'home' | grep 'false' | grep -v 'syslog' | grep -v 'hwid' | grep -v 'token' | grep -v '::/' | awk -F ':' '{print $1}'); do
    echo "$u"
  done
}

# ======== USER TABLE ========
data_user() {
  cat_users=$(cat "/etc/passwd" | grep 'home' | grep 'false' | grep -v 'syslog' | grep -v '::/' | grep -v 'hwid\|token')
  if [[ -z "$(echo "${cat_users}" | head -1)" ]]; then
    echo -e " ${YELLOW}  ⚠  No users registered yet${NC}"
    return 1
  fi
  echo -e " ${CYAN}$(printf '%-3s %-12s %-12s %-18s %-14s %s' '#' 'USER' 'PASS' 'EXPIRES' 'REMAINING' 'STATUS')${NC}"
  echo -e " ${CYAN}────────────────────────────────────────────────────────${NC}"

  i=1
  while read line; do
    u=$(echo "$line" | awk -F ':' '{print $1}')
    pass=$(echo "$line" | awk -F ':' '{print $5}' | cut -d ',' -f2)
    [[ "${#pass}" -gt 12 ]] && pass="••••••••"
    Limit=$(echo "$line" | awk -F ':' '{print $5}' | cut -d ',' -f1)

    expfile="/etc/rms-users/${u}.expiry"
    if [[ -f "$expfile" ]]; then
      exp_ts=$(cat "$expfile")
      exp_display=$(date -d "@$exp_ts" '+%Y-%m-%d %H:%M')
      now=$(date +%s)
      remaining_s=$(( exp_ts - now ))
      if [[ $remaining_s -le 0 ]]; then
        remaining="${RED}Expired${NC}"
        stat="${RED}● BLK${NC}"
      else
        rem_h=$(( remaining_s / 3600 ))
        rem_m=$(( (remaining_s % 3600) / 60 ))
        rem_s=$(( remaining_s % 60 ))
        if [[ $rem_h -gt 0 ]]; then
          remaining="${GREEN}${rem_h}h ${rem_m}m${NC}"
        elif [[ $rem_m -gt 0 ]]; then
          remaining="${YELLOW}${rem_m}m ${rem_s}s${NC}"
        else
          remaining="${RED}${rem_s}s${NC}"
        fi
        stat="${GREEN}● ULK${NC}"
      fi
    else
      fecha=$(chage -l "$u" | sed -n '4p' | awk -F ': ' '{print $2}')
      exp_display="$fecha"
      if [[ $(date +%s) -gt $(date '+%s' -d "${fecha}" 2>/dev/null) ]]; then
        remaining="${RED}Expired${NC}"
        stat="${RED}● BLK${NC}"
      else
        EXPTIME="$(($(($(date '+%s' -d "${fecha}") - $(date +%s))) / 86400))"
        remaining="${GREEN}${EXPTIME}d${NC}"
        stat="${GREEN}● ULK${NC}"
      fi
    fi

    echo -e " ${ORANGE}$(printf '%-3s' "$i")${NC} ${WHITE}$(printf '%-12s' "$u")${NC} ${WHITE}$(printf '%-12s' "$pass")${NC} ${CYAN}$(printf '%-18s' "$exp_display")${NC} $remaining  $stat"
    let i++
  done <<<"$cat_users"
}

# ======== ADD USER ========
add_user_core() {
  local valid=$(date '+%Y-%m-%d' -d "@$4")
  local osl_v=$(openssl version | awk '{print $2}' | cut -c1-5)
  if [[ $osl_v == '1.1.1' ]]; then
    local pass=$(openssl passwd -6 "$2")
  else
    local pass=$(openssl passwd -1 "$2")
  fi
  useradd -M -s /bin/false -e "$valid" -p "$pass" -c "$3,$2" "$1" 2>/dev/null
  msj=$?
}

new_user() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${YELLOW}           ➕  CREATE USER ACCOUNT            ${CYAN}║${NC}"
  rms_bar
  data_user
  rms_bar

  while true; do
    echo -ne " ${CYAN}❯ Username        : ${WHITE}"; read nameuser
    [[ -z "$nameuser" ]] && echo -e "${RED} ✘ Username required${NC}" && continue
    [[ "$nameuser" == "0" ]] && return
    [[ "${#nameuser}" -lt 3 ]] && echo -e "${RED} ✘ Min 3 characters${NC}" && continue
    [[ "${#nameuser}" -gt 12 ]] && echo -e "${RED} ✘ Max 12 characters${NC}" && continue
    [[ "$(show_users | grep -w "$nameuser")" ]] && echo -e "${RED} ✘ User already exists${NC}" && continue
    break
  done

  while true; do
    echo -ne " ${CYAN}❯ Password        : ${WHITE}"; read userpass
    [[ -z "$userpass" ]] && echo -e "${RED} ✘ Password required${NC}" && continue
    [[ "${#userpass}" -lt 3 ]] && echo -e "${RED} ✘ Min 3 characters${NC}" && continue
    break
  done

  while true; do
    echo -ne " ${CYAN}❯ Connection Limit: ${WHITE}"; read limit
    [[ -z "$limit" ]] && echo -e "${RED} ✘ Limit required${NC}" && continue
    [[ ! "$limit" =~ ^[0-9]+$ ]] && echo -e "${RED} ✘ Numbers only${NC}" && continue
    break
  done

  echo ""
  echo -e " ${CYAN}❯ Expiry Duration:${NC}"
  echo -e "   ${GREEN}[1]${NC} ${WHITE}Minutes${NC}"
  echo -e "   ${GREEN}[2]${NC} ${WHITE}Hours${NC}"
  echo -e "   ${GREEN}[3]${NC} ${WHITE}Days${NC}"
  echo ""
  echo -ne " ${CYAN}❯ Choose (1/2/3)  : ${WHITE}"; read dur_type

  case $dur_type in
    1)
      echo -ne " ${CYAN}❯ Number of Minutes: ${WHITE}"; read dur_val
      total_seconds=$(( dur_val * 60 ))
      dur_label="${dur_val} minute(s)"
      ;;
    2)
      echo -ne " ${CYAN}❯ Number of Hours  : ${WHITE}"; read dur_val
      total_seconds=$(( dur_val * 3600 ))
      dur_label="${dur_val} hour(s)"
      ;;
    3)
      echo -ne " ${CYAN}❯ Number of Days   : ${WHITE}"; read dur_val
      total_seconds=$(( dur_val * 86400 ))
      dur_label="${dur_val} day(s)"
      ;;
    *)
      echo -e "${RED} ✘ Invalid option${NC}"
      return
      ;;
  esac

  exp_timestamp=$(( $(date +%s) + total_seconds ))
  add_user_core "$nameuser" "$userpass" "$limit" "$exp_timestamp"

  if [[ $msj -eq 0 ]]; then
    mkdir -p /etc/rms-users
    echo "$exp_timestamp" > "/etc/rms-users/${nameuser}.expiry"
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${GREEN}       ✔  User Created Successfully!          ${CYAN}║${NC}"
    echo -e "${CYAN}╠══════════════════════════════════════════════╣${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Server IP  :${NC} ${WHITE}$request_public_ip${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Port Range :${NC} ${WHITE}1-65535${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Username   :${NC} ${WHITE}$nameuser${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Password   :${NC} ${WHITE}$userpass${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Duration   :${NC} ${WHITE}$dur_label${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Expires    :${NC} ${WHITE}$(date -d "@$exp_timestamp" '+%Y-%m-%d %H:%M:%S')${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW} Limit      :${NC} ${WHITE}$limit connections${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  else
    echo -e "${RED} ✘ Error: User not created${NC}"
  fi
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

# ======== REMOVE USER ========
rm_user() {
  pkill -u $1 2>/dev/null
  kill -9 $(ps -u "$1" -o pid= 2>/dev/null) 2>/dev/null
  userdel --force "$1" 2>/dev/null
  rm -f "/etc/rms-users/${1}.expiry"
  msj=$?
}

remove_user() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${RED}            🗑  REMOVE USER                   ${CYAN}║${NC}"
  rms_bar
  data_user
  rms_bar
  echo -e " ${RED}[0]${NC} ${WHITE}GO BACK${NC}"
  rms_bar
  echo -ne " ${CYAN}❯ Type username to remove: ${WHITE}"; read user_del
  [[ "$user_del" == "0" ]] && return
  [[ -z "$user_del" ]] && echo -e "${RED} ✘ Invalid${NC}" && return

  rm_user "$user_del"
  if [[ $msj -eq 0 ]]; then
    echo -e "${GREEN} ✔ User ${WHITE}$user_del${GREEN} removed successfully${NC}"
  else
    echo -e "${RED} ✘ Failed to remove user${NC}"
  fi
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

# ======== BLOCK/UNBLOCK ========
block_user() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${YELLOW}         🔒  BLOCK / UNBLOCK USER             ${CYAN}║${NC}"
  rms_bar
  data_user
  rms_bar
  echo -e " ${RED}[0]${NC} ${WHITE}GO BACK${NC}"
  rms_bar
  echo -ne " ${CYAN}❯ Type username: ${WHITE}"; read user_sel
  [[ "$user_sel" == "0" ]] && return
  [[ -z "$user_sel" ]] && return

  if [[ $(passwd --status $user_sel 2>/dev/null | cut -d ' ' -f2) == "P" ]]; then
    pkill -u "$user_sel" 2>/dev/null
    usermod -L "$user_sel" 2>/dev/null
    echo -e "${RED} ✘ $user_sel has been BLOCKED and kicked${NC}"
  else
    usermod -U "$user_sel" 2>/dev/null
    echo -e "${GREEN} ✔ $user_sel has been UNBLOCKED${NC}"
  fi
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

