# ======== EXPIRY LOG ========
expiry_log() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${MAGENTA}           📋  EXPIRY LOG                     ${CYAN}║${NC}"
  rms_bar
  if [[ ! -s /var/log/rms-expiry.log ]]; then
    echo -e " ${YELLOW}  ⚠  No expiry events logged yet${NC}"
  else
    tail -20 /var/log/rms-expiry.log | while read line; do
      echo -e " ${RED}▸${NC} ${WHITE}$line${NC}"
    done
  fi
  rms_bar_bot
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

# ======== UDP TOGGLE ========
reset_udp_custom() {
  if [[ $(systemctl is-active udp-custom) == 'active' ]]; then
    systemctl stop udp-custom && systemctl disable udp-custom
    echo -e "${RED} ✘ UDP-Custom STOPPED${NC}"
  else
    systemctl start udp-custom && systemctl enable udp-custom
    systemctl is-active udp-custom &>/dev/null && echo -e "${GREEN} ✔ UDP-Custom STARTED${NC}" || echo -e "${RED} ✘ Failed to start${NC}"
  fi
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

# ======== TWEAK SPEED ========
tweak_udp_speed() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${RED}      ⚡  TWEAK UDP SPEED [CAUTION!]          ${CYAN}║${NC}"
  rms_bar
  echo -e "${RED}  ⚠  This may or may not work on your OS${NC}"
  sleep 2
  echo 0 >/proc/sys/net/ipv4/tcp_timestamps
  echo 4194304 >/proc/sys/net/core/wmem_max
  echo 4194304 >/proc/sys/net/core/rmem_max
  echo 16384 87380 16777216 >/proc/sys/net/ipv4/tcp_wmem
  echo 16384 87380 16777216 >/proc/sys/net/ipv4/tcp_rmem
  echo 4096 >/proc/sys/net/ipv4/tcp_max_syn_backlog
  ulimit -n 65535
  systemctl restart NetworkManager 2>/dev/null
  sleep 2
  echo -e "${GREEN} ✔ Speed tweak applied!${NC}"
  rms_bar_bot
  echo -ne "\n ${CYAN}❯ Press enter to continue...${NC}"; read dummy
}

# ======== UNINSTALL ========
uninstall_rms() {
  rms_banner
  rms_bar
  echo -e "${CYAN}║${RED}        🗑  UNINSTALL RMS MANAGER             ${CYAN}║${NC}"
  rms_bar
  echo -ne " ${RED}❯ Are you sure? (y/N): ${WHITE}"; read confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return
  systemctl stop udp-custom udpgw rms-expiry 2>/dev/null
  systemctl disable udp-custom udpgw rms-expiry 2>/dev/null
  rm -rf /etc/systemd/system/udp-custom.service
  rm -rf /etc/systemd/system/udpgw.service
  rm -rf /etc/systemd/system/rms-expiry.service
  rm -rf /root/udp /etc/UDPCustom /bin/udpgw
  rm -rf /etc/rms-users /var/log/rms-expiry.log /etc/rms-expiry.sh
  systemctl daemon-reload
  echo -e "${GREEN} ✔ Uninstallation complete${NC}"
  rm -rf /usr/bin/udp
  exit
}

